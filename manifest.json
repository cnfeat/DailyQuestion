{
  "manifest_version": 3,
  "name": "日课一问 | 每日一问，破局人生",
  "version": "1.0.0",
  "description": "每日一问，破局人生。一个基于卡片创作系统的深度思考工具。",
  "author": "cnfeat",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://github.com/cnfeat/DailyQuestion"
  ]
}