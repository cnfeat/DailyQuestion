{
  "manifest_version": 3,
  "name": "日课一问 | 每日三省，破局人生",
  "version": "2.0.01",
  "description": "每日三省，破局人生。「日课一问」是一套精选卡片问题集，内置 365+ 个启发性问题，让你每次打开浏览器新标签页，都是直接与灵魂深度对话。",
  "author": "cnfeat",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}